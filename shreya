import os
import shutil
import glob

categories = ['Asthama', 'CROUP', 'LTRI', 'NORMAL', 'PNEUMONIA', 'URTI']
source_root = 'Source'

for cat in categories:
    os.makedirs(os.path.join(source_root, cat), exist_ok=True)

# Move files matching category name into its folder
for f in glob.glob(f'{source_root}/*.wav'):
    for cat in categories:
        if cat.lower() in f.lower():  # simple match
            shutil.move(f, os.path.join(source_root, cat, os.path.basename(f)))
            break

print("Files organized into Source/<CATEGORY>/ successfully.")
